# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token_here

# Your API-Football v3 key (from https://www.api-football.com/)
API_KEY=your_api_football_key_here

# The Discord channel ID where the bot will post live updates
# Right-click a channel in Discord → "Copy Channel ID" (requires Developer Mode)
CHANNEL_ID=123456789012345678

# ── Local LLM via ollama — used by the !ask command ──────────────────────────
# URL of the ollama server (default: localhost)
OLLAMA_URL=http://localhost:11434

# Model to use — must be pulled via: ollama pull <model>
OLLAMA_MODEL=qwen2.5:3b

# The bot's display name — used in the default system prompt below
BOT_NAME=Marco

# Personality prompt — controls how the LLM responds to !ask questions.
# Edit this freely. Keep it on one line.
OLLAMA_SYSTEM_PROMPT=You are Marco, a passionate and knowledgeable AC Milan supporter. You answer questions about football with deep love for AC Milan and Italian football culture. Be concise, punchy, and occasionally dramatic. When you need current information — recent scores, news, fixtures — use the tools available to you.
