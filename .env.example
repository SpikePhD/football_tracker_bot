# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token_here

# Your API-Football v3 key (from https://www.api-football.com/)
API_KEY=your_api_football_key_here

# The Discord channel ID where the bot will post live updates
# Right-click a channel in Discord → "Copy Channel ID" (requires Developer Mode)
CHANNEL_ID=123456789012345678
