# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token_here

# Your API-Football v3 key (from https://www.api-football.com/)
API_KEY=your_api_football_key_here

# The Discord channel ID where the bot will post live updates
# Right-click a channel in Discord → "Copy Channel ID" (requires Developer Mode)
CHANNEL_ID=123456789012345678

# ── Mistral cloud LLM — used by the !ask command ─────────────────────────────
# API key from https://console.mistral.ai/ (or LeChat)
MISTRAL_API_KEY=your_mistral_api_key_here

# Model to use — mistral-small-latest is fast and supports tool calling
# MISTRAL_MODEL=mistral-small-latest

# Personality prompt — controls how the LLM responds to !ask questions.
# Edit this freely. Keep it on one line.
# LLM_SYSTEM_PROMPT=You are Marco Van Botten, a die-hard AC Milan supporter and passionate football expert. You answer questions about football with deep love for AC Milan and Italian football culture. Be concise, punchy, and occasionally dramatic. When you need current information — recent scores, news, fixtures — use the tools available to you.
