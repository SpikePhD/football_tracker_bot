# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token_here

# Your API-Football v3 key (from https://www.api-football.com/)
API_KEY=your_api_football_key_here

# The Discord channel ID where the bot will post live updates
# Right-click a channel in Discord → "Copy Channel ID" (requires Developer Mode)
CHANNEL_ID=123456789012345678

# ── LLM — used by the !ask command ───────────────────────────────────────────
# Any OpenAI-compatible provider works. Set the three vars below to switch.

# Your API key for the chosen provider
LLM_API_KEY=your_api_key_here

# Base URL of the provider's OpenAI-compatible API
# Mistral (default): https://api.mistral.ai/v1
# OpenAI:            https://api.openai.com/v1
# Groq:              https://api.groq.com/openai/v1
# Together AI:       https://api.together.xyz/v1
# Local ollama:      http://localhost:11434/v1
LLM_BASE_URL=https://api.mistral.ai/v1

# Model name — must be supported by the chosen provider and support tool calling
# Mistral:    mistral-small-latest, mistral-large-latest
# OpenAI:     gpt-4o-mini, gpt-4o
# Groq:       llama-3.1-8b-instant, llama3-70b-8192
# Together:   meta-llama/Llama-3-8b-chat-hf
# Ollama:     qwen2.5:1.5b
LLM_MODEL=mistral-small-latest

# Personality prompt — controls how the LLM responds to !ask questions.
# Edit this freely. Keep it on one line.
# LLM_SYSTEM_PROMPT=You are Marco Van Botten, a die-hard AC Milan supporter and passionate football expert. You answer questions about football with deep love for AC Milan and Italian football culture. Be concise, punchy, and occasionally dramatic. IMPORTANT: Never answer from memory for anything that could be factually wrong or outdated — this includes ages, birthdays, current roles, recent results, transfer news, standings, or any specific statistic. Always use web_search for these. Only skip the search for timeless facts you are completely certain about (e.g. who won a specific historic final).

# Comma-separated domains preferred by !ask web_search before broad-web fallback
TRUSTED_SPORT_DOMAINS=acmilan.com,gazzetta.it,corrieredellosport.it,calciomercato.com,espn.com,bbc.com,skysports.com,theathletic.com,uefa.com,fifa.com,legaseriea.it

# Minimum trusted-source hits required before skipping broad-web fallback
WEB_SEARCH_MIN_TRUSTED_RESULTS=2
